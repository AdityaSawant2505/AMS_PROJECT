################################################################################
# General .gitignore for Visual Studio and .NET Projects
################################################################################

# Ignore Visual Studio-specific folders and files
.vs/
.vs/*

# Ignore temporary build artifacts (bin/ and obj/)
[Bb]in/
[Oo]bj/
**/[Bb]in/
**/[Oo]bj/

# Ignore intermediate files generated by Visual Studio/MSBuild
*.dll
*.exe
*.pdb
*.cache
*.tmp
*.log
*.tlog
*.trace
*.genruntimeconfig.cache
*.sourcelink.json
*.csproj.FileListAbsolute.txt
*.csproj.AssemblyReference.cache
*.csproj.CoreCompileInputs.cache
*.csproj.Up2Date
*.DesignTimeResolveAssemblyReferencesInput.cache
apphost.exe

# Ignore NuGet files and folders
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
packages/
artifacts/
.nuget/

# Ignore Rider/JetBrains IDE files
.idea/
*.sln.iml

# Ignore ASP.NET-specific generated files
Generated_Code/
*.dbmdl
*.opendb
AssemblyInfo.cs

# Ignore runtime and debug configuration/documentation
*.xml
*.json
*.config

# Ignore Code Coverage files
*.coverage
*.coveragexml

# Ignore files created by dotnet tools
**/test-results/

################################################################################
# Specific Rules for Dependent Projects
################################################################################

# Exclude build artifacts in subprojects like BLL and DLL
../BLL/[Bb]in/
../BLL/[Oo]bj/
../DLL/[Bb]in/
../DLL/[Oo]bj/

################################################################################
# Prevent Essential Files from Being Ignored
################################################################################

# Allow markdown files in bin/ and obj/ folders
!bin/**/*.md
!obj/**/*.md
