################################################################################
# General .gitignore for Visual Studio and .NET Projects
################################################################################

# Ignore Visual Studio-generated folders
.vs/
.vs/*

# Ignore Visual Studio solution and user-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.ide.*

# Ignore build artifacts (bin/ and obj/) and nested folders
[Bb]in/
[Oo]bj/
**/[Bb]in/
**/[Oo]bj/
**/[Bb]in/**/*
**/[Oo]bj/**/*

# Ignore files generated during builds or rebuilds
*.dll
*.exe
*.pdb
*.cache
*.tmp
*.log
*.tlog
*.trace
*.csproj.FileListAbsolute.txt
*.csproj.AssemblyReference.cache
*.csproj.CoreCompileInputs.cache
*.csproj.Up2Date
*.DesignTimeResolveAssemblyReferencesInput.cache
*.genruntimeconfig.cache
*.sourcelink.json
apphost.exe

# Ignore NuGet-generated files
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
packages/
artifacts/
*.nuget/

# Ignore Rider/JetBrains IDE files
.idea/
*.sln.iml

# Ignore publish-related folders
publish/
wwwroot/
out/

# Ignore ASP.NET autogenerated and runtime files
Generated_Code/
*.dbmdl
*.opendb
AssemblyInfo.cs

# Ignore XML and JSON configuration or documentation files
*.xml
*.json
*.config

# Ignore ReSharper/Code analysis files
_ReSharper*/
*.DotSettings.user

# Ignore Code Coverage files
*.coverage
*.coveragexml

# Ignore files created by dotnet tools
**/test-results/

################################################################################
# Prevent Essential Files from Being Ignored
################################################################################

# Allow markdown files in bin/ and obj/
!bin/**/*.md
!obj/**/*.md

################################################################################
# Custom Rules for Dependent Projects
################################################################################

# Ignore build artifacts for BLL and DLL projects
../BLL/[Bb]in/
../BLL/[Oo]bj/
../BLL/[Bb]in/**/*
../BLL/[Oo]bj/**/*
../DLL/[Bb]in/
../DLL/[Oo]bj/
../DLL/[Bb]in/**/*
../DLL/[Oo]bj/**/*
