################################################################################
# General .gitignore for Visual Studio Projects
################################################################################

# Ignore Visual Studio-generated folders
.vs/
.vs/*

# Ignore Visual Studio solution and user-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.ide.*

# Ignore build artifacts (bin/ and obj/)
[Bb]in/
[Oo]bj/

# Ignore files generated by NuGet
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/

# Ignore build logs and debug-specific files
*.log
*.tlog
*.trace

# Ignore temporary files and caches
*.cache
*.backup.json
*.tmp
~$*
Thumbs.db
Desktop.ini

# Ignore files generated during runtime or compilation
*.pdb
*.exe
*.dll
*.config
*.app
*.csproj.user
*.csproj.transient.*
*.dbmdl
*.opendb

# Ignore IDE-specific configuration files
.idea/
*.sln.iml

# Ignore publish-related folders
publish/
wwwroot/
out/

################################################################################
# Additional Rules
################################################################################

# Ignore JSON configuration and XML documentation files
*.json
*.xml

# Ignore ReSharper/Code analysis files
_ReSharper*/
*.DotSettings.user

# Ignore files related to Code Coverage
*.coverage
*.coveragexml

# Ignore files created by dotnet tools
**/test-results/

# Prevent tracking of NuGet packages folder
packages/
*.nuget/

# Prevent tracking of generated markdown files in bin/ and obj/
!bin/**/*.md
!obj/**/*.md

# Ignore autogenerated files for ASP.NET projects
Generated_Code/

# Ignore assembly information files
AssemblyInfo.cs

################################################################################
# Custom Rules for Your Project
################################################################################

# Ignore specific build outputs from dependent projects
../BLL/[Bb]in/
../BLL/[Oo]bj/
../DLL/[Bb]in/
../DLL/[Oo]bj/

# Explicitly exclude DLLs, configs, and logs from dependent projects
../BLL/bin/**/*.dll
../BLL/bin/**/*.config
../DLL/bin/**/*.dll
../DLL/bin/**/*.config

# Ignore build artifacts recursively in all subdirectories
*/bin/
*/obj/
