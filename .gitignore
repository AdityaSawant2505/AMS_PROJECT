################################################################################
# General .gitignore for Visual Studio Projects
################################################################################

# Ignore Visual Studio-generated folders
.vs/
.vs/*

# Ignore Visual Studio solution and user-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.ide.*

# Ignore temporary build files
[Bb]in/
[Oo]bj/

# Ignore files generated by NuGet
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/

# Ignore build logs and debug-specific files
*.log
*.tlog
*.trace

# Ignore temporary files and caches
*.cache
*.backup.json
*.tmp
~$*
Thumbs.db
Desktop.ini

# Ignore files generated during runtime
*.pdb
*.exe
*.dll
*.app
*.csproj.user
*.csproj.transient.*
*.dbmdl
*.opendb

# Ignore Rider/JetBrains IDE files
.idea/
*.sln.iml

# Ignore Publish-related folders
publish/
wwwroot/
out/

################################################################################
# Additional Rules
################################################################################

# Ignore generated JSON configuration
*.json

# Ignore generated XML documentation
*.xml

# Ignore ReSharper/Code analysis files
_ReSharper*/
*.DotSettings.user

# Ignore files related to Code Coverage
*.coverage
*.coveragexml

# Ignore files created by dotnet tools
**/test-results/

# Prevent ignoring README.md or other essential files in bin/obj
!bin/**/*.md
!obj/**/*.md
